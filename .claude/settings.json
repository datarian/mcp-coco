{
  "enabledPlugins": {
    "mcp-server-dev@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/check-readme.sh",
            "if": "Bash(git commit*)",
            "timeout": 10,
            "statusMessage": "Checking README freshness..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.py|*.pyi) cd \"${CLAUDE_PROJECT_DIR:-.}\" && uv run ruff check --fix \"$f\" ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
