# Postgres target (CocoIndex creates/manages the doc_embeddings table here).
# Inside the devcontainer the db service is reachable as "db":
DATABASE_URL=postgresql://cocoindex:cocoindex@db:5432/cocoindex
# For local (non-devcontainer) use, point at localhost instead:
# DATABASE_URL=postgresql://cocoindex:cocoindex@localhost:5432/cocoindex

# CocoIndex's incremental state store (LMDB). Keep this on a persisted path:
# if it's ephemeral, every index run re-embeds everything from scratch.
COCOINDEX_DB=./.cocoindex/state.db

# Sentence-transformers model used for both indexing and query embedding.
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Avoid uv hardlink warnings when cache and venv are on different filesystems.
UV_LINK_MODE=copy
